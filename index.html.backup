<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>Wave on Pulse</title>
  <link rel="icon" type="image/x-icon" href="public/WaveLogo.jpg">
  <!-- Bubblegum Sans from Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bubblegum+Sans&display=swap" rel="stylesheet">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --primary-blue: #0099ff;
    }
    body {
      font-family: 'Bubblegum Sans', cursive, system-ui, sans-serif;
      background:#0a0a0a;
      color:#e0f7ff;
      line-height:1.6;
      overflow-x:hidden;
      -webkit-tap-highlight-color: transparent;
    }
    h1, h2, h3, h4, p, a, button, .marquee-text, .logo-title, .section-title,
    .nav-link, .footer-section, .footer-bottom, .footer-brand {
      font-family: 'Bubblegum Sans', cursive, system-ui, sans-serif;
    }
    /* ====================== MARQUEE ====================== */
    .marquee-container {
      position: sticky;
      top: 0;
      z-index: 9999;
      height: 52px;
      display: flex;
      align-items: center;
      background: linear-gradient(90deg, rgba(0,153,255,0.85), rgba(0,204,255,0.7), rgba(0,255,255,0.55));
      border-bottom: 2px solid #00ccff;
      box-shadow: 0 4px 20px rgba(0,204,255,0.35);
      backdrop-filter: blur(12px);
    }
    .marquee-text {
      font-size: clamp(1.1rem, 4vw, 1.28rem);
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #e0f7ff;
      text-shadow: 0 0 15px #00ccff;
      white-space: nowrap;
      animation: marqueeScroll 100s linear infinite;
    }
    @keyframes marqueeScroll { 0%{transform:translateX(100%)} 100%{transform:translateX(-100%)} }
    /* ====================== HEADER ====================== */
    .header {
      position: sticky;
      top: 52px;
      z-index: 900;
      background: rgba(8,12,25,0.94);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(0,204,255,0.35);
      padding: 0.8rem 0;
    }
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 5vw;
      gap: 3.5rem;
    }
    .logo-title {
      font-size: 5.0rem;
      background: linear-gradient(90deg, #0099ff, #00ccff, #00ffff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 25px rgba(0,204,255,0.6);
      white-space: normal;
      line-height: 1.05;
      animation: pulse-glow 4s ease-in-out infinite alternate;
      transition: background 0.6s ease, text-shadow 0.45s ease, transform 0.35s ease;
      padding-right: 18px;
    }
    .logo-title:hover {
      animation-play-state: paused;
      background: linear-gradient(90deg, #ff006e, #ff3399, #ff66cc);
      -webkit-background-clip: text;
      background-clip: text;
      text-shadow: 0 0 60px #ff006e, 0 0 90px #ff3399, 0 0 120px #ff66cc;
      transform: translateY(-6px) scale(1.03);
    }
    @keyframes pulse-glow {
      from { text-shadow: 0 0 25px rgba(0,204,255,0.6), 0 0 45px rgba(0,204,255,0.4); }
      to { text-shadow: 0 0 45px rgba(0,204,255,0.95), 0 0 75px rgba(0,204,255,0.75), 0 0 110px rgba(0,153,255,0.55); }
    }
    /* Hamburger */
    .hamburger {
      display: none;
      background: none;
      border: none;
      font-size: 2.2rem;
      color: #00ccff;
      cursor: pointer;
      padding: 0.4rem;
      width: 50px;
      height: 50px;
      align-items: center;
      justify-content: center;
    }
    nav {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .nav-link {
      color: #e0f7ff;
      text-decoration: none;
      padding: 0.6rem 1.2rem;
      border-radius: 10px;
      background: rgba(0,153,255,0.15);
      border: 1px solid rgba(0,204,255,0.35);
      transition: all 0.35s;
      font-size: 1.02rem;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .nav-link:hover {
      background: linear-gradient(135deg, rgba(255,0,110,0.25), rgba(236,19,172,0.18));
      border-color: #ff006e;
      color: #ffccdd;
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(255,0,110,0.35);
    }
    .nav-donate {
      background: linear-gradient(135deg, #ff006e, #ff3399) !important;
      border-color: #ff66cc !important;
      color: #fff !important;
      font-weight: bold;
    }
    /* Mobile Menu */
    .mobile-menu {
      display: none;
      position: fixed;
      top: 104px;
      left: 0;
      right: 0;
      background: rgba(8,12,25,0.98);
      backdrop-filter: blur(18px);
      border-top: 1px solid rgba(0,204,255,0.35);
      padding: 2rem 5vw;
      z-index: 1000;
      flex-direction: column;
      gap: 1rem;
    }
    .mobile-menu.active {
      display: flex;
    }
    .mobile-menu a {
      padding: 1.2rem 1.5rem;
      font-size: 1.45rem;
      background: rgba(0,153,255,0.15);
      border-radius: 12px;
      text-align: center;
      border: 1px solid rgba(0,204,255,0.35);
    }
    /* ====================== CONTAINER ====================== */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 5vw;
    }
    /* ====================== HERO ====================== */
    .hero {
      position: relative;
      height: calc(100vh - 52px);
      min-height: 680px;
      margin-top: -12vh;
    }
    .hero-video {
      position: absolute;
      inset: 0;
      z-index: -1;
      overflow: hidden;
    }
    #hero-video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(1.18) saturate(1.22);
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 25%, rgba(0,0,0,0.12) 55%, rgba(0,0,0,0.28) 100%);
      z-index: 1;
    }
    .sound-toggle {
      position: absolute;
      bottom: 6rem;
      right: 2.5rem;
      z-index: 3;
      background: linear-gradient(135deg, #0099ff, #00ccff);
      border: none;
      color: #000;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      font-size: 1.8rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 20px rgba(0,204,255,0.5);
      transition: all 0.4s;
    }
    .sound-toggle:hover {
      transform: translateY(-4px) scale(1.1);
      box-shadow: 0 12px 40px rgba(0,204,255,0.9);
    }
    /* ====================== SECTIONS ====================== */
    .section { padding: 8rem 0; }
    .section-title {
      text-align: center;
      font-size: clamp(2.8rem, 6vw, 3.8rem);
      margin-bottom: 4rem;
      background: linear-gradient(90deg, #00ccff, #0099ff, #ff006e);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 25px rgba(0,204,255,0.5);
      transition: text-shadow 0.4s ease, transform 0.3s ease;
    }
    .section-title:hover {
      text-shadow: 0 0 50px #ff006e, 0 0 70px #00ccff, 0 0 100px #00ffff;
      transform: translateY(-6px);
    }
    /* Live Card */
    #live .live-card {
      background: rgba(10,18,40,0.8);
      backdrop-filter: blur(18px);
      border: 2.5px solid rgba(0,204,255,0.6);
      border-radius: 28px;
      padding: 3.8rem 2.4rem;
      max-width: 960px;
      margin: 0 auto;
      box-shadow: 0 0 70px rgba(0,204,255,0.4);
      text-align: center;
    }
    #live h3 {
      font-size: clamp(2.2rem, 5.5vw, 2.8rem);
      margin-bottom: 1.2rem;
      background: linear-gradient(90deg, #00ffff, #00ccff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 30px rgba(0,255,255,0.6);
    }
    /* Features & Podcasts */
    .features-grid, .podcasts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 2.5rem;
    }
    .feature-card, .podcast-card {
      background: rgba(12,20,45,0.6);
      backdrop-filter: blur(14px);
      border: 1.5px solid rgba(0,204,255,0.4);
      border-radius: 20px;
      padding: 2.4rem 1.8rem;
      text-align: center;
      box-shadow: 0 0 25px rgba(0,153,255,0.2);
      transition: all 0.4s;
    }
    .feature-card:hover, .podcast-card:hover {
      transform: translateY(-14px);
      border-color: #ff006e;
      box-shadow: 0 25px 60px rgba(255,0,110,0.35);
    }
    .feature-icon {
      font-size: 4.5rem;
      margin-bottom: 1.2rem;
      filter: drop-shadow(0 0 20px #00ccff);
    }
    .podcast-thumbnail {
      height: 200px;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #00ccff, #ff006e);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 25px rgba(0,204,255,0.3);
    }
    .podcast-thumbnail img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    /* Donation */
    .donation-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
      gap: 2.5rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .crypto-box, .fiat-box {
      background: rgba(12,20,45,0.75);
      backdrop-filter: blur(16px);
      border-radius: 24px;
      padding: 2.8rem 2.2rem;
      text-align: center;
      border: 2px solid;
      transition: all 0.4s;
    }
    .crypto-box { border-color: #00ccff; }
    .fiat-box { border-color: #ff006e; }
    .crypto-box:hover, .fiat-box:hover {
      transform: translateY(-12px);
      box-shadow: 0 30px 70px rgba(0,204,255,0.4);
    }
    .coin-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(0,204,255,0.08);
      padding: 1rem 1.2rem;
      border-radius: 12px;
      margin: 1rem 0;
    }
    .coin-row button {
      background: #00ccff;
      color: #000;
      border: none;
      padding: 10px 18px;
      border-radius: 50px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s;
      min-height: 44px;
    }
    .coin-row button:hover {
      background: #00ffff;
      transform: scale(1.05);
    }
    .qr-code {
      width: 220px;
      height: 220px;
      border: 5px solid #00ccff;
      border-radius: 16px;
      box-shadow: 0 0 40px rgba(0,204,255,0.6);
      margin: 1.5rem auto;
    }
    /* Schedule */
    .schedule-table {
      background: rgba(12,20,45,0.6);
      backdrop-filter: blur(16px);
      border: 1.5px solid rgba(0,204,255,0.45);
      border-radius: 20px;
      overflow: hidden;
    }
    .schedule-header,
    .schedule-row {
      display: grid;
      grid-template-columns: 1fr 1fr 2fr;
      padding: 1.2rem 2rem;
      align-items: center;
    }
    .schedule-header {
      background: rgba(0,153,255,0.18);
      border-bottom: 1px solid rgba(0,204,255,0.3);
      font-weight: bold;
    }
    .schedule-row {
      border-bottom: 1px solid rgba(0,204,255,0.2);
    }
    .schedule-row:last-child {
      border-bottom: none;
    }
    /* Footer */
    .footer {
      padding: 4rem 0 2rem;
      background: rgba(8,12,25,0.96);
      border-top: 2px solid rgba(0,204,255,0.4);
    }
    .footer-content {
      display: flex;
      justify-content: center;
      max-width: 500px;
      margin: 0 auto;
    }
    .footer-section h4 {
      font-size: 2.2rem;
      margin-bottom: 1.8rem;
      text-align: center;
      background: linear-gradient(90deg, #00ccff, #0099ff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .footer-section a {
      color: #e0f7ff;
      text-decoration: none;
      display: block;
      margin: 0.8rem 0;
      font-size: 1.35rem;
      transition: all 0.35s;
      text-align: center;
    }
    .footer-section a:hover {
      color: #ff006e;
      transform: translateX(6px);
      text-shadow: 0 0 10px #ff006e;
    }
    /* ====================== PULSECHAIN LOGO + COPYRIGHT (very last thing) ====================== */
    .bottom-pulsechain {
      text-align: center;
      padding: 3rem 5vw 2.5rem;
      background: rgba(10,15,35,0.6);
      border-top: 1px solid rgba(0,204,255,0.3);
    }
    .pulsechain-logo {
      height: 90px;
      filter: drop-shadow(0 0 20px #00ccff);
      transition: transform 0.4s ease;
    }
    .pulsechain-logo:hover {
      transform: scale(1.1);
    }
    /* ====================== NOW PLAYING BAR ====================== */
    #now-playing {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 99999;
      background: rgba(8,12,25,0.95);
      backdrop-filter: blur(20px);
      border-top: 2px solid #00ccff;
      padding: 12px 5vw;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: 0 -4px 30px rgba(0,204,255,0.4);
      transition: transform 0.4s ease;
    }
    #now-playing.hidden {
      transform: translateY(100%);
    }
    .now-playing-left {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1;
    }
    .live-dot {
      width: 12px;
      height: 12px;
      background: #ff006e;
      border-radius: 50%;
      box-shadow: 0 0 12px #ff006e;
      animation: pulse-live 1.5s infinite;
    }
    .now-playing-title {
      font-size: 1.1rem;
      font-weight: bold;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .now-playing-controls button {
      background: linear-gradient(135deg, #00ccff, #00ffff);
      border: none;
      color: #000;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      font-size: 1.6rem;
      cursor: pointer;
      box-shadow: 0 0 20px rgba(0,204,255,0.7);
      transition: all 0.3s;
    }
    .now-playing-controls button:hover {
      transform: scale(1.15);
      box-shadow: 0 0 30px rgba(0,255,255,0.9);
    }
    @keyframes pulse-live { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
    /* ====================== RESPONSIVE ====================== */
    @media (max-width: 900px) {
      .header-inner { justify-content: space-between; }
      nav { display: none; }
      .hamburger { display: flex; }
      .logo-title { font-size: 2.8rem; }
      .hero { height: calc(100vh - 100px); margin-top: -8vh; }
      .section { padding: 6rem 0; }
    }
    @media (max-width: 768px) {
      #play-live { width: 100px; height: 100px; font-size: 2.4rem; }
      .sound-toggle { bottom: 4rem; right: 1.5rem; width: 48px; height: 48px; font-size: 1.5rem; }
      .donation-grid { grid-template-columns: 1fr; }
      .pulsechain-logo { height: 72px; }
    }
    @media (max-width: 640px) {
      .schedule-header,
      .schedule-row {
        grid-template-columns: 1fr 1fr;
      }
      .schedule-header div:last-child,
      .schedule-row div:last-child {
        grid-column: span 2;
      }
    }
    /* Backdrop-filter fallback for older browsers */
    @supports not (backdrop-filter: blur(18px)) {
      .header, .marquee-container, .mobile-menu, .live-card, .feature-card, .podcast-card,
      .crypto-box, .fiat-box, .schedule-table {
        background: rgba(10,15,35,0.95) !important;
      }
    }
  </style>
</head>
<body>
  <!-- Marquee -->
  <div class="marquee-container">
    <div class="marquee-text">
      WAVE ON PULSE • Decentralized Radio • 24/7 Uncensorable Broadcasting • Built on PulseChain • No Central Authority • Free Speech • Crypto Community • Blockchain Audio • Digital Freedom • Peer-to-Peer • Open Source • Community Driven • Trustless • Permissionless • Sovereign • Resilient • Borderless • Global Reach • Web3 Radio • PulseChain Ecosystem • Audio Liberation • WAVE ON PULSE •
    </div>
  </div>
  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <h1 class="logo-title">Wave on Pulse<br>Radio</h1>
     
      <!-- Hamburger -->
      <button id="hamburger" class="hamburger" aria-label="Menu">☰</button>
     
      <!-- Desktop Nav -->
      <nav>
        <a href="#home" class="nav-link">Home</a>
        <a href="#live" class="nav-link">Live</a>
        <a href="#podcasts" class="nav-link">Podcasts</a>
        <a href="#schedule" class="nav-link">Schedule</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#donate" class="nav-link nav-donate">💰 Donate</a>
      </nav>
    </div>
  </header>
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu">
    <a href="#home" class="nav-link">Home</a>
    <a href="#live" class="nav-link">Live</a>
    <a href="#podcasts" class="nav-link">Podcasts</a>
    <a href="#schedule" class="nav-link">Schedule</a>
    <a href="#about" class="nav-link">About</a>
    <a href="#donate" class="nav-link nav-donate">💰 Donate</a>
  </div>
  <main>
    <!-- Hero -->
    <section class="hero" id="home">
      <div class="hero-video">
        <video id="hero-video" autoplay loop muted playsinline preload="metadata" poster="public/hero-poster.jpg">
          <source src="public/Radio_Dial_Frequency_Pattern_Video (1).mp4" type="video/mp4">
        </video>
        <div class="hero-overlay"></div>
        <button class="sound-toggle" id="video-sound-toggle" title="Toggle video sound">🔇</button>
      </div>
    </section>
    <!-- Features -->
    <section class="section" id="features">
      <div class="container">
        <h2 class="section-title">Why Wave on Pulse?</h2>
        <div class="features-grid">
          <div class="feature-card"><div class="feature-icon">🚀</div><h3>Decentralized</h3><p>No central authority, no censorship</p></div>
          <div class="feature-card"><div class="feature-icon">🔒</div><h3>Secure & On-chain</h3><p>Built natively on PulseChain blockchain</p></div>
          <div class="feature-card"><div class="feature-icon">📡</div><h3>Global Access</h3><p>Clearnet + censorship resistant streaming</p></div>
          <div class="feature-card"><div class="feature-icon">📱</div><h3>Mobile Ready</h3><p>Listen anywhere — desktop, mobile, anywhere</p></div>
        </div>
      </div>
    </section>
    <!-- Live -->
    <section class="section" id="live">
      <div class="container">
        <h2 class="section-title">Now Live</h2>
        <div class="live-card">
          <h3>Current Show: PulseChain Pioneers</h3>
          <p class="host">Hosted by CryptoInnovator</p>
          <p class="description">Live discussion on the latest in decentralized finance and PulseChain developments</p>
          <button id="play-live">▶</button>
        </div>
      </div>
    </section>
    <!-- Podcasts -->
    <section class="section" id="podcasts">
      <div class="container">
        <h2 class="section-title">Featured Podcasts</h2>
        <div class="podcasts-grid">
          <div class="podcast-card">
            <div class="podcast-thumbnail"><img src="assets/podcast1.jpg" alt="" loading="lazy"></div>
            <h3>DeFi Deep Dive</h3>
            <p>Weekly analysis of decentralized finance protocols</p>
          </div>
          <div class="podcast-card">
            <div class="podcast-thumbnail"><img src="assets/podcast2.jpg" alt="" loading="lazy"></div>
            <h3>PulseChain News</h3>
            <p>Daily updates on PulseChain ecosystem</p>
          </div>
          <div class="podcast-card">
            <div class="podcast-thumbnail"><img src="assets/podcast3.jpg" alt="" loading="lazy"></div>
            <h3>Blockchain Builders</h3>
            <p>Interviews with blockchain developers</p>
          </div>
        </div>
      </div>
    </section>
    <!-- Schedule -->
    <section class="section" id="schedule">
      <div class="container">
        <h2 class="section-title">Weekly Schedule (UTC)</h2>
        <div class="schedule-table">
          <div class="schedule-header">
            <div>Day</div><div>Time</div><div>Show</div>
          </div>
          <div class="schedule-row"><div>Monday</div><div>14:00</div><div>PulseChain Pioneers</div></div>
          <div class="schedule-row"><div>Tuesday</div><div>16:00</div><div>DeFi Deep Dive</div></div>
          <div class="schedule-row"><div>Wednesday</div><div>18:00</div><div>Blockchain Builders</div></div>
          <div class="schedule-row"><div>Thursday</div><div>20:00</div><div>PulseChain News</div></div>
          <div class="schedule-row"><div>Friday</div><div>22:00</div><div>Crypto Conversations</div></div>
          <div class="schedule-row"><div>Saturday</div><div>20:00</div><div>Weekend Alpha Drop</div></div>
          <div class="schedule-row"><div>Sunday</div><div>19:00</div><div>Community Open Mic</div></div>
        </div>
      </div>
    </section>
    <!-- About -->
    <section class="section" id="about">
      <div class="container">
        <h2 class="section-title">About Wave on Pulse</h2>
        <p style="max-width:820px; margin:0 auto 3rem; font-size:1.18rem; text-align:center;">
          Wave on Pulse is a censorship-resistant, decentralized radio network built directly on the PulseChain blockchain.
        </p>
        <div style="display:flex; justify-content:center; gap:5rem; flex-wrap:wrap;">
          <div style="text-align:center;">
            <div style="font-size:3.2rem; color:#00ccff;">1,200+</div>
            <p>Active Listeners</p>
          </div>
          <div style="text-align:center;">
            <div style="font-size:3.2rem; color:#00ccff;">24/7</div>
            <p>Live Streaming</p>
          </div>
          <div style="text-align:center;">
            <div style="font-size:3.2rem; color:#00ccff;">100%</div>
            <p>Decentralized Ethos</p>
          </div>
        </div>
      </div>
    </section>
    <!-- Donate -->
    <section class="section" id="donate" style="background: linear-gradient(180deg, #0a0a0a, #121a35);">
      <div class="container">
        <h2 class="section-title">Support the Wave</h2>
        <p style="max-width:860px; margin:0 auto 3.5rem; font-size:1.32rem; text-align:center; opacity:0.94;">
          Help keep Wave on Pulse broadcasting freely on PulseChain.<br>
          Every donation powers uncensorable radio for the decentralized community.
        </p>
        <div class="donation-grid">
          <div class="crypto-box">
            <h3 style="color:#00ffff; font-size:2.1rem; margin-bottom:1.8rem;">💎 Crypto Donations</h3>
            <div class="coin-row">
              <div style="text-align:left;">
                <strong>EVM Compatible</strong><br>
                <span style="font-size:0.95rem; opacity:0.8;">(PLS • ETH • USDC • DAI • USDT)</span><br>
                <span id="evm-addr" style="font-family:monospace; font-size:1.05rem; word-break:break-all;">0x21f03eB5488d17a1295Fe1e7B8a2182AF0Ce8A5c</span>
              </div>
              <button onclick="copyAddress('evm-addr')">COPY</button>
            </div>
            <div class="coin-row">
              <div style="text-align:left;">
                <strong>Bitcoin (BTC)</strong><br>
                <span id="btc-addr" style="font-family:monospace; font-size:1.05rem; word-break:break-all;">bc1qevl6avf8mexkngn2ag8pq5srxdpax82yn76vgq</span>
              </div>
              <button onclick="copyAddress('btc-addr')">COPY</button>
            </div>
            <p style="margin-top:2rem; opacity:0.85;">Scan QR for fast send (EVM recommended) (Coming soon)</p>
            <img src="assets/qr-pls.png" alt="EVM QR" class="qr-code">
          </div>
          <div class="fiat-box">
            <h3 style="color:#ff66cc; font-size:2.1rem; margin-bottom:1.8rem;">💵 Fiat / Traditional</h3>
            <p style="font-size:1.4rem; margin:2rem 0;">Support via popular payment apps</p>
            <a href="https://www.paypal.me/YOURPAYPALUSERNAME" target="_blank" style="display:block; background:linear-gradient(135deg,#ff006e,#ff3399); color:#fff; padding:18px 40px; border-radius:50px; font-size:1.35rem; text-decoration:none; margin:1.2rem auto; max-width:320px; box-shadow:0 0 35px rgba(255,0,110,0.6);">Donate with PayPal</a>
            <a href="https://cash.app/$YOURCASHAPP" target="_blank" style="display:block; background:#00d632; color:#000; padding:18px 40px; border-radius:50px; font-size:1.35rem; text-decoration:none; margin:1.2rem auto; max-width:320px; box-shadow:0 0 30px rgba(0,214,50,0.5);">Donate with Cash App</a>
            <a href="https://venmo.com/YOURVENMO" target="_blank" style="display:block; background:#3d95ce; color:#fff; padding:18px 40px; border-radius:50px; font-size:1.35rem; text-decoration:none; margin:1.2rem auto; max-width:320px; box-shadow:0 0 30px rgba(61,149,206,0.6);">Donate with Venmo</a>
            <p style="margin-top:2.5rem; font-size:1.05rem; opacity:0.8;">
              Prefer another method? DM us on <a href="https://x.com/WaveOnPulse" target="_blank" style="color:#00ccff;">X @WaveOnPulse</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <!-- Footer (cleaned up) -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h4>Connect With Us</h4>
          <a href="https://x.com/WaveOnPulse" target="_blank">X / Twitter</a>
          <a href="#" target="_blank">Telegram</a>
          <a href="#" target="_blank">GitHub</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- PulseChain Logo + final copyright line (very last thing on the page) -->
  <div class="bottom-pulsechain">
    <img src="public/pulsechain-logo.png" alt="PulseChain" class="pulsechain-logo">
    <p style="margin-top: 1.5rem; font-size: 1.25rem; opacity: 0.9; letter-spacing: 2px;">
      © 2025 Wave on Pulse – Built on PulseChain – Decentralized • Uncensorable • Community Owned
    </p>
  </div>

  <!-- NOW PLAYING BAR -->
  <div id="now-playing" class="hidden">
    <div class="now-playing-left">
      <div class="live-dot"></div>
      <span style="font-size:0.95rem; opacity:0.9;">NOW PLAYING</span>
      <div id="np-title" class="now-playing-title">PulseChain Pioneers</div>
    </div>
    <div class="now-playing-controls">
      <button id="np-play-btn">▶</button>
    </div>
  </div>

  <!-- Audio elements -->
  <audio id="click-sound" src="public/click.mp3" preload="auto"></audio>
  <audio id="live-stream" src="YOUR_ACTUAL_LIVE_STREAM_URL.mp3" preload="auto" loop></audio>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // === VIDEO SOUND TOGGLE (fixed + more robust) ===
      const video = document.getElementById('hero-video');
      const toggle = document.getElementById('video-sound-toggle');
      if (video && toggle) {
        video.muted = true;
        toggle.textContent = '🔇';

        const handleToggle = () => {
          video.muted = !video.muted;
          toggle.textContent = video.muted ? '🔇' : '🔊';
          if (!video.muted && video.paused) {
            video.play().catch(() => {});
          }
        };

        toggle.addEventListener('click', handleToggle);
        // Also allow tapping the video area itself as backup
        video.addEventListener('click', (e) => {
          if (e.target.tagName === 'VIDEO') handleToggle();
        });

        const tryPlay = () => video.play().catch(() => {});
        window.addEventListener('load', tryPlay);
        document.addEventListener('click', tryPlay, {once:true});
        document.addEventListener('touchstart', tryPlay, {once:true});
      }

      // Click sound
      const click = document.getElementById('click-sound');
      if (click) {
        click.volume = 0.35;
        document.querySelectorAll('.nav-link, .sound-toggle, #play-live, #hamburger').forEach(el => {
          el.addEventListener('click', () => {
            click.currentTime = 0;
            click.play().catch(() => {});
          });
        });
      }

      // Live stream play/pause + Now Playing bar sync
      const liveAudio = document.getElementById('live-stream');
      const playBtn = document.getElementById('play-live');
      const npBar = document.getElementById('now-playing');
      const npTitle = document.getElementById('np-title');
      const npBtn = document.getElementById('np-play-btn');
      function toggleLiveStream() {
        if (liveAudio.paused) {
          liveAudio.play().catch(() => {});
          playBtn.textContent = '⏸';
          npBtn.textContent = '⏸';
          npBar.classList.remove('hidden');
          npTitle.textContent = document.querySelector('#live h3').textContent || "Live on PulseChain";
        } else {
          liveAudio.pause();
          playBtn.textContent = '▶';
          npBtn.textContent = '▶';
        }
      }
      if (liveAudio && playBtn) {
        playBtn.addEventListener('click', toggleLiveStream);
        npBtn.addEventListener('click', toggleLiveStream);
      }

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          document.querySelector(a.getAttribute('href'))?.scrollIntoView({behavior:'smooth'});
        });
      });

      // Copy address
      window.copyAddress = function(id) {
        const el = document.getElementById(id);
        const address = el.textContent.trim();
        navigator.clipboard.writeText(address).then(() => {
          const btn = el.parentElement.parentElement.querySelector('button');
          const originalText = btn.textContent;
          btn.textContent = '✅ COPIED!';
          btn.style.background = '#00ff88';
          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.background = '#00ccff';
          }, 2000);
        }).catch(() => {
          alert('Failed to copy. Please copy manually: ' + address);
        });
      };

      // Hamburger + Mobile Menu
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          const isOpen = mobileMenu.classList.toggle('active');
          hamburger.textContent = isOpen ? '✕' : '☰';
        });
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.remove('active');
            hamburger.textContent = '☰';
          });
        });
      }
    });
  </script>
</body>
</html>
